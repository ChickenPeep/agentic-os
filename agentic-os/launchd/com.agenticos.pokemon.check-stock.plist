<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.agenticos.pokemon.check-stock</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/gabri/agentic-os-server/pokemon-hunter/run.sh</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <!-- 5 min default. Release-day mode: drop to 60-120 then launchctl unload/load. -->
  <key>StartInterval</key>
  <integer>300</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/gabri/agentic-os-server/logs/pokemon-check-stock-stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/gabri/agentic-os-server/logs/pokemon-check-stock-stderr.log</string>
</dict>
</plist>
